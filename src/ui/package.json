{
  "name": "ui",
  "version": "1.2.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/axios": "^0.14.4",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react-window": "^1.8.8",
    "axios": "^1.13.5",
    "i18next": "^25.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "15.5.2",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "react-window": "^2.2.7",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "start": "BROWSERSLIST_IGNORE_OLD_DATA=1 react-scripts start",
    "dev": "BROWSERSLIST_IGNORE_OLD_DATA=1 react-scripts start",
    "build": "BROWSERSLIST_IGNORE_OLD_DATA=1 react-scripts build",
    "test": "BROWSERSLIST_IGNORE_OLD_DATA=1 react-scripts test",
    "test:coverage": "BROWSERSLIST_IGNORE_OLD_DATA=1 react-scripts test --watchAll=false --coverage",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/index.tsx",
      "!src/reportWebVitals.ts",
      "!src/setupTests.ts",
      "!src/**/*.test.{ts,tsx}",
      "!src/**/*.spec.{ts,tsx}"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/src/setupTests.ts"
    ],
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-router|react-router-dom)/)"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 17,
        "functions": 20,
        "lines": 25,
        "statements": 25
      },
      "./src/api.ts": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./src/queueStore.ts": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "./src/storage.ts": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/react-router-dom": "^5.3.3",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "axios-mock-adapter": "^2.1.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "nth-check": "^2.1.1",
    "postcss": "^8.4.31",
    "browserslist": "^4.28.0"
  }
}
